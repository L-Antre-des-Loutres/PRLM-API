<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}PRLM API{% endblock %}</title>
        <link rel="icon" href="/images/logo/favicon.ico">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="header-main">
            <nav class="header-container">
                <div class="header-logo-wrapper">
                    <a href="/"><img src="/images/logo/prlm-api-full-white.png" alt="Logo PRLM" class="header-logo-img"></a>
                </div>

                <button class="header-mobile-toggle" id="prlmToggle" aria-label="Toggle menu">
                    <span class="header-burger-icon"></span>
                </button>

                <ul class="header-menu" id="prlmMenu">
                    <li class="header-item">
                        <a href="/" class="header-link">Home</a>
                    </li>

                    <li class="header-item header-has-dropdown">
                        <p class="header-link">Manage</p>
                        <ul class="header-dropdown">
                            <li class="header-dropdown-item">
                                <a href="/panel/egg_groups" class="header-dropdown-link">Egg Groups</a>
                            </li>
                            <li class="header-dropdown-item">
                                <a href="/panel/abilities" class="header-dropdown-link">Abilities</a>
                            </li>
                            <li class="header-dropdown-item">
                                <a href="/panel/game_or_region" class="header-dropdown-link">Game or Regions</a>
                            </li>
                            <li class="header-dropdown-item">
                                <a href="/panel/leveling_rate" class="header-dropdown-link">Leveling Rates</a>
                            </li>
                            <li class="header-dropdown-item">
                                <a href="/panel/pkmn_types" class="header-dropdown-link">Types</a>
                            </li>
                            <li class="header-dropdown-item">
                                <a href="/panel/moves" class="header-dropdown-link">Moves</a>
                            </li>
                            <li class="header-dropdown-item">
                                <a href="/panel/pkmn" class="header-dropdown-link">Pokemons</a>
                            </li>
                        </ul>
                    </li>

                    <li class="header-item">
                        {% if app.user %}
                            <a href="/logout" class="header-login-btn">Logout</a>
                        {% else %}
                            <a href="/login" class="header-login-btn">Login</a>
                        {% endif %}
                    </li>
                </ul>
            </nav>
        </header>

        <main>
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
