{% extends 'base.html.twig' %}

{% block body %}
    <div class="panel-dual-card-wrapper">
        <div class="panel-dual-card-container">

            <div class="panel-default-card table-section">
                <div class="panel-default-card-header">
                    <h2 class="colorful-title">
                        List of Egg Groups
                    </h2>
                </div>

                <div class="panel-table-responsive">
                    <table class="panel-table">
                        <thead>
                        <tr>
                            <th width="50">ID</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th class="text-end">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for group in egg_groups %}
                            <tr>
                                <td class="text-muted">#{{ group.id }}</td>
                                <td class="fw-bold">{{ group.name }}</td>
                                <td>{{ group.websiteDescription }}</td>
                                <td class="text-end panel-table-actions-cell">

                                    <!-- Edit Button -->
                                    <a href="{{ path('app_panel_egg_groups_index', {'id': group.id}) }}" class="default-button info-button">
                                        Edit
                                    </a>

                                    <!-- Delete Button -->
                                    <form method="post" action="{{ path('app_panel_egg_groups_delete', {'id': group.id}) }}" style="display: inline-block" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ group.id) }}">
                                        <button class="default-button danger-button">Delete</button>
                                    </form>

                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" style="text-align: center">No Egg Groups found</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="panel-default-card">
                <div class="panel-default-card-header">
                    <h2 class="colorful-title">
                        {% if is_edit_mode %}
                            Edit: <span class="text-gold">{{ form.vars.value.name }}</span>
                        {% else %}
                            New Egg Group
                        {% endif %}
                    </h2>
                </div>

                {% for message in app.flashes('success') %}
                    <div class="panel-alert-default panel-alert-success">{{ message }}</div>
                {% endfor %}

                {{ form_start(form, {'attr': {'class': 'panel-form'}}) }}

                <div class="panel-form-group">
                    {{ form_label(form.name, null, {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'text-input'}}) }}
                    {{ form_errors(form.name) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.websiteDescription, null, {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.websiteDescription, {'attr': {'class': 'text-input'}}) }}
                    {{ form_errors(form.websiteDescription) }}
                </div>

                <div class="form-actions">
                    {{ form_widget(form.save, {
                        'label': is_edit_mode ? 'Update' : 'Create',
                        'attr': {'class': 'default-button orange-button'}
                    }) }}
                    {% if is_edit_mode %}
                        <a href="{{ path('app_panel_egg_groups_index') }}" class="default-button info-button">
                            Cancel
                        </a>
                    {% endif %}
                </div>

                {{ form_end(form) }}
            </div>

        </div>
    </div>
{% endblock %}
