{% extends 'base.html.twig' %}

{% block body %}
    <div class="panel-dual-card-wrapper">
        <div class="panel-dual-card-container" style="grid-template-columns: 1fr 730px">

            {# --- SECTION TABLEAU (GAUCHE) --- #}
            <div class="panel-default-card table-section">
                <div class="panel-default-card-header">
                    <h2 class="colorful-title">
                        List of Moves
                    </h2>
                </div>

                <div class="panel-table-responsive">
                    <table class="panel-table">
                        <thead>
                        <tr>
                            <th width="40">ID</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Cat.</th>
                            <th>Stats (Pwr/Acc/PP)</th>
                            <th class="text-end">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for move in moves %}
                            <tr>
                                <td class="text-muted">#{{ move.id }}</td>
                                <td class="fw-bold">{{ move.name }}</td>

                                {# Affichage du Type (via la relation) #}
                                <td>
                                    {% if move.typeID %}
                                        {{ move.typeID.name }}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>

                                <td>
                                    {% if move.Category %}
                                        {{ move.Category.value }}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>

                                {# Affichage compact des stats #}
                                <td style="font-size: 0.9em;">
                                    {{ move.basePower|default('-') }} / {{ move.baseAccuracy|default('-') }} / {{ move.basePP }}
                                </td>

                                <td class="text-end panel-table-actions-cell">
                                    <a href="{{ path('app_panel_moves_index', {'id': move.id}) }}" class="default-button info-button">
                                        Edit
                                    </a>

                                    <form method="post" action="{{ path('app_panel_moves_delete', {'id': move.id}) }}" style="display: inline-block" onsubmit="return confirm('Are you sure you want to delete this move?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ move.id) }}">
                                        <button class="default-button danger-button">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" style="text-align: center">No Moves found</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            {# --- SECTION FORMULAIRE (DROITE) --- #}
            <div class="panel-default-card">
                <div class="panel-default-card-header">
                    <h2 class="colorful-title">
                        {% if is_edit_mode %}
                            Edit: <span class="text-gold">{{ form.vars.value.name }}</span>
                        {% else %}
                            New Move
                        {% endif %}
                    </h2>
                </div>

                {% for message in app.flashes('success') %}
                    <div class="panel-alert-default panel-alert-success">{{ message }}</div>
                {% endfor %}

                {{ form_start(form, {'attr': {'class': 'panel-form'}}) }}

                <div class="panel-form-group">
                    {{ form_label(form.name, null, {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'text-input'}}) }}
                    {{ form_errors(form.name) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.typeID, null, {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.typeID) }} {# Le style est géré dans le FormType #}
                    {{ form_errors(form.typeID) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.Category, null, {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.Category, {'attr': {'class': 'text-input'}}) }}
                    {{ form_errors(form.Category) }}
                </div>

                {# Petite astuce : on regroupe les inputs numériques pour gagner de la place verticale #}
                <div style="display: flex; gap: 10px;">
                    <div class="panel-form-group" style="flex: 1;">
                        {{ form_label(form.basePower, 'Power', {'label_attr': {'class': 'panel-label'}}) }}
                        {{ form_widget(form.basePower, {'attr': {'class': 'text-input'}}) }}
                    </div>
                    <div class="panel-form-group" style="flex: 1;">
                        {{ form_label(form.baseAccuracy, 'Accuracy', {'label_attr': {'class': 'panel-label'}}) }}
                        {{ form_widget(form.baseAccuracy, {'attr': {'class': 'text-input'}}) }}
                    </div>
                    <div class="panel-form-group" style="flex: 1;">
                        {{ form_label(form.basePP, 'PP', {'label_attr': {'class': 'panel-label'}}) }}
                        {{ form_widget(form.basePP, {'attr': {'class': 'text-input'}}) }}
                    </div>
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.moveRange, 'Range', {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.moveRange, {'attr': {'class': 'text-input'}}) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.inGameDescription, 'In-Game Desc', {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.inGameDescription, {'attr': {'class': 'text-input', 'rows': 3}}) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.websiteDescription, 'Website Desc', {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.websiteDescription, {'attr': {'class': 'text-input', 'rows': 3}}) }}
                </div>

                <div class="form-actions">
                    {{ form_widget(form.save, {
                        'label': is_edit_mode ? 'Update' : 'Create',
                        'attr': {'class': 'default-button orange-button'}
                    }) }}
                    {% if is_edit_mode %}
                        <a href="{{ path('app_panel_moves_index') }}" class="default-button info-button">
                            Cancel
                        </a>
                    {% endif %}
                </div>

                {{ form_end(form) }}
            </div>

        </div>
    </div>
{% endblock %}
