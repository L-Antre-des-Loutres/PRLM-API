{% extends 'base.html.twig' %}

{% block body %}
    <div class="panel-dual-card-wrapper">
        <div class="panel-dual-card-container">

            {# --- SECTION TABLEAU (GAUCHE) --- #}
            <div class="panel-default-card table-section">
                <div class="panel-default-card-header">
                    <h2 class="colorful-title">
                        List of Pokémon Types
                    </h2>
                </div>

                <div class="panel-table-responsive">
                    <table class="panel-table">
                        <thead>
                        <tr>
                            <th width="50">ID</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th class="text-end">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for type in pkmn_types %}
                            <tr>
                                <td class="text-muted">#{{ type.id }}</td>
                                <td class="fw-bold">{{ type.name }}</td>
                                <td>{{ type.websiteDescription|u.truncate(30, '...') }}</td>
                                <td class="text-end panel-table-actions-cell">

                                    <a href="{{ path('app_panel_pkmn_types_index', {'id': type.id}) }}" class="default-button info-button">
                                        Edit
                                    </a>

                                    <form method="post" action="{{ path('app_panel_pkmn_types_delete', {'id': type.id}) }}" style="display: inline-block" onsubmit="return confirm('Are you sure you want to delete this type?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ type.id) }}">
                                        <button class="default-button danger-button">Delete</button>
                                    </form>

                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" style="text-align: center">No Types found</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            {# --- SECTION FORMULAIRE (DROITE) --- #}
            <div class="panel-default-card">
                <div class="panel-default-card-header">
                    <h2 class="colorful-title">
                        {% if is_edit_mode %}
                            Edit: <span class="text-gold">{{ form.vars.value.name }}</span>
                        {% else %}
                            New Type
                        {% endif %}
                    </h2>
                </div>

                {% for message in app.flashes('success') %}
                    <div class="panel-alert-default panel-alert-success">{{ message }}</div>
                {% endfor %}

                {{ form_start(form, {'attr': {'class': 'panel-form'}}) }}

                <div class="panel-form-group">
                    {{ form_label(form.name, null, {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'text-input'}}) }}
                    {{ form_errors(form.name) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.websiteDescription, null, {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.websiteDescription, {'attr': {'class': 'text-input'}}) }}
                    {{ form_errors(form.websiteDescription) }}
                </div>

                <hr style="border-color: var(--usual_cream); margin: 1rem 0;">
                <h4 style="font-size: 0.9rem; color: var(--rlm_gold_darker); margin-bottom: 1rem;">Matchups (Hold CTRL to select multiple)</h4>

                {# Offense #}
                <div class="panel-form-group">
                    {{ form_label(form.superEffectiveOn, 'Super Effective On', {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.superEffectiveOn) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.notVeryEffectiveOn, 'Not Very Effective On', {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.notVeryEffectiveOn) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.noEffectOn, 'No Effect On', {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.noEffectOn) }}
                </div>

                {# Defense #}
                <div class="panel-form-group">
                    {{ form_label(form.weakTo, 'Weak To', {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.weakTo) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.resistantTo, 'Resistant To', {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.resistantTo) }}
                </div>

                <div class="panel-form-group">
                    {{ form_label(form.immuneFrom, 'Immune From', {'label_attr': {'class': 'panel-label'}}) }}
                    {{ form_widget(form.immuneFrom) }}
                </div>

                <div class="form-actions">
                    {{ form_widget(form.save, {
                        'label': is_edit_mode ? 'Update' : 'Create',
                        'attr': {'class': 'default-button orange-button'}
                    }) }}
                    {% if is_edit_mode %}
                        <a href="{{ path('app_panel_pkmn_types_index') }}" class="default-button info-button">
                            Cancel
                        </a>
                    {% endif %}
                </div>

                {{ form_end(form) }}
            </div>

        </div>
    </div>
{% endblock %}
